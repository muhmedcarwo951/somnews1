<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Somnews AI Pro</title>

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: radial-gradient(circle at top, #0b1220, #050814);
        color: white;
    }

    header {
        text-align: center;
        padding: 20px;
        font-size: 26px;
        font-weight: bold;
        letter-spacing: 2px;
    }

    .subtitle {
        font-size: 12px;
        color: #93c5fd;
        margin-top: 5px;
    }

    .search-bar {
        display: flex;
        justify-content: center;
        margin: 10px 0 20px 0;
    }

    input {
        width: 60%;
        padding: 10px;
        border-radius: 10px;
        border: none;
        outline: none;
        font-size: 14px;
    }

    .container {
        display: grid;
        grid-template-columns: 1.3fr 1fr 1fr;
        gap: 16px;
        padding: 16px;
    }

    .card {
        background: rgba(17, 24, 39, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 14px;
        height: 75vh;
        overflow-y: auto;
    }

    h2 {
        font-size: 16px;
        border-bottom: 1px solid #374151;
        padding-bottom: 8px;
    }

    .item {
        background: rgba(0,0,0,0.25);
        padding: 10px;
        border-radius: 10px;
        margin-bottom: 10px;
        transition: 0.2s;
    }

    .item:hover {
        transform: scale(1.02);
        background: rgba(255,255,255,0.05);
    }

    a {
        color: #60a5fa;
        font-weight: bold;
        text-decoration: none;
    }

    .meta {
        font-size: 11px;
        color: #9ca3af;
        margin-top: 5px;
    }

    .summary {
        font-size: 12px;
        color: #d1d5db;
        margin-top: 6px;
    }

    footer {
        text-align: center;
        padding: 10px;
        font-size: 11px;
        color: #6b7280;
    }
</style>
</head>

<body>

<header>
    🌍 SOMNEWS AI PRO
    <div class="subtitle">Live AI-style news • sports • economy dashboard</div>
</header>

<div class="search-bar">
    <input type="text" id="search" placeholder="Search news..." onkeyup="filterNews()" />
</div>

<div class="container">

    <!-- NEWS -->
    <div class="card">
        <h2>📰 Global News</h2>
        <div id="news">Loading...</div>
    </div>

    <!-- SPORTS -->
    <div class="card">
        <h2>⚽ Sports</h2>
        <div class="item">Live sports API ready slot</div>
        <div class="item">Football • NBA • UFC • Tennis</div>
    </div>

    <!-- ECONOMY -->
    <div class="card">
        <h2>💰 Economy</h2>
        <div id="economy">Loading...</div>
    </div>

</div>

<footer>
    © 2026 Somnews AI Pro
</footer>

<script>

let newsData = [];

// Simple AI-style summary (basic shortening logic)
function summarize(text) {
    if (!text) return "No summary available.";
    return text.split(" ").slice(0, 12).join(" ") + "...";
}

// NEWS
async function loadNews() {
    const res = await fetch("https://hn.algolia.com/api/v1/search?query=world&tags=story");
    const data = await res.json();

    newsData = data.hits;

    renderNews(newsData);
}

function renderNews(data) {
    let html = "";

    data.slice(0, 15).forEach(n => {
        html += `
            <div class="item">
                <a href="${n.url}" target="_blank">${n.title}</a>
                <div class="meta">⭐ ${n.points || 0} points</div>
                <div class="summary">🧠 ${summarize(n.title)}</div>
            </div>
        `;
    });

    document.getElementById("news").innerHTML = html;
}

// SEARCH FILTER
function filterNews() {
    const value = document.getElementById("search").value.toLowerCase();

    const filtered = newsData.filter(n =>
        (n.title || "").toLowerCase().includes(value)
    );

    renderNews(filtered);
}

// ECONOMY
async function loadEconomy() {
    const res = await fetch("https://api.exchangerate.host/latest?base=USD");
    const data = await res.json();

    const rates = data.rates;
    const list = ["EUR", "GBP", "JPY", "ISK"];

    let html = "";

    list.forEach(c => {
        html += `
            <div class="item">
                1 USD = ${rates[c]} ${c}
            </div>
        `;
    });

    document.getElementById("economy").innerHTML = html;
}

loadNews();
loadEconomy();

</script>

</body>
</html>